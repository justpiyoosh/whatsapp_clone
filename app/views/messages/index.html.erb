<div class="h-screen bg-gray-50 flex" 
     data-chat-room="<%= [current_user.id, @recipient.id].sort.join('_') %>"
     data-current-username="<%= current_user.username %>">
  <!-- Sidebar with user list -->
  <div class="w-80 bg-white border-r border-gray-200 flex flex-col shadow-sm">
    <!-- Header -->
    <div class="bg-green-600 text-white p-6 flex justify-between items-center">
      <div>
        <h1 class="text-xl font-bold">WhatsApp Clone</h1>
        <p class="text-green-100 text-sm mt-1">Real-time messaging</p>
      </div>
      <div class="flex items-center space-x-3">
        <div class="text-right">
          <p class="text-sm font-medium"><%= current_user.username %></p>
          <p class="text-xs text-green-100">Active now</p>
        </div>
        <%= link_to logout_path, method: :delete, class: "text-green-100 hover:text-white transition-colors", data: { turbo_method: :delete } do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
        <% end %>
      </div>
    </div>

    <!-- User list -->
    <div class="flex-1 overflow-y-auto">
      <div class="p-4">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Chats</h2>
        <% @users.each do |user| %>
          <%= link_to chat_with_path(user.username), class: "block mb-2" do %>
            <div class="flex items-center p-3 rounded-lg transition-colors <%= @recipient == user ? 'bg-green-50 border border-green-200' : 'hover:bg-gray-50' %>">
              <div class="w-12 h-12 bg-gradient-to-br from-green-400 to-green-600 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-sm">
                <%= user.username.first.upcase %>
              </div>
              <div class="ml-3 flex-1">
                <h3 class="font-semibold text-gray-900"><%= user.username %></h3>
                <p class="text-sm text-gray-500">Click to start chatting</p>
              </div>
              <% if @recipient == user %>
                <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Chat area -->
  <div class="flex-1 flex flex-col bg-white">
    <!-- Chat header -->
    <div class="bg-white border-b border-gray-200 p-6 shadow-sm">
      <div class="flex items-center">
        <div class="w-12 h-12 bg-gradient-to-br from-green-400 to-green-600 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-sm">
          <%= @recipient.username.first.upcase %>
        </div>
        <div class="ml-4">
          <h2 class="text-xl font-bold text-gray-900"><%= @recipient.username %></h2>
          <div class="flex items-center mt-1">
            <div class="w-2 h-2 bg-gray-400 rounded-full mr-2"></div>
            <p class="text-sm text-gray-500">Last seen recently</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div id="messages" class="flex-1 overflow-y-auto p-6 space-y-4 bg-gray-50">
      <% if @messages.empty? %>
        <div class="text-center py-12">
          <div class="w-16 h-16 bg-gray-200 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No messages yet</h3>
          <p class="text-gray-500">Start a conversation with <%= @recipient.username %></p>
        </div>
      <% else %>
        <% @messages.each do |message| %>
          <div class="flex <%= message.sender == current_user ? 'justify-end' : 'justify-start' %>">
            <div class="max-w-xs lg:max-w-md">
              <div class="<%= message.sender == current_user ? 'bg-green-600 text-white' : 'bg-white border border-gray-200' %> rounded-2xl px-4 py-3 shadow-sm">
                <p class="text-sm leading-relaxed"><%= message.content %></p>
                <p class="text-xs <%= message.sender == current_user ? 'text-green-100' : 'text-gray-500' %> mt-2 text-right">
                  <%= message.created_at.strftime("%H:%M") %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Message input -->
    <div class="bg-white border-t border-gray-200 p-6">
      <%= form_with model: Message.new, url: messages_path, class: "flex items-end space-x-3", data: { turbo: false } do |form| %>
        <%= form.hidden_field :recipient_username, value: @recipient.username %>
        <div class="flex-1 relative">
          <%= form.text_field :content, placeholder: "Type a message...", class: "w-full border border-gray-300 rounded-2xl px-4 py-3 pr-12 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent resize-none", rows: 1 %>
        </div>
        <%= form.submit "Send", class: "bg-green-600 text-white px-6 py-3 rounded-2xl hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors font-medium shadow-sm" %>
      <% end %>
      
      <!-- Debug button for testing Action Cable -->
      <div class="mt-2 text-center">
        <button onclick="testActionCable()" class="text-xs text-gray-500 hover:text-gray-700 underline">
          Test Action Cable
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Handle form submission and scroll to bottom
  document.addEventListener('DOMContentLoaded', function() {
    const messagesContainer = document.getElementById('messages');
    if (messagesContainer) {
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    const form = document.querySelector('form');
    const input = document.querySelector('input[name="message[content]"]');
    
    if (form && input) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(form);
        
        fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
          }
        })
        .then(response => {
          if (response.ok) {
            input.value = '';
          }
        })
        .catch(error => {
          console.error('Error:', error);
        });
      });
    }
  });

  // Test Action Cable function
  function testActionCable() {
    console.log('🧪 Testing Action Cable...');
    const chatRoom = document.querySelector('[data-chat-room]')?.dataset.chatRoom;
    const currentUsername = document.querySelector('[data-current-username]')?.dataset.currentUsername;
    
    console.log('Chat room:', chatRoom);
    console.log('Current username:', currentUsername);
    console.log('Chat subscription:', window.chatSubscription);
    
    // Test the subscription
    if (window.chatSubscription) {
      console.log('✅ Chat subscription exists');
      console.log('Connection state:', window.chatSubscription.connection.isOpen());
    } else {
      console.log('❌ No chat subscription found');
    }
    
    // Test manual broadcast
    fetch(`/messages/<%= @recipient.username %>/test`)
      .then(response => response.json())
      .then(data => {
        console.log('Test broadcast response:', data);
      })
      .catch(error => {
        console.error('Test broadcast error:', error);
      });
  }
</script>
